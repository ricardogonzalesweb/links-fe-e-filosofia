---
import { SEO } from "astro-seo";
import { Image } from "astro:assets";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";

const links = [
  { label: "Ebook Exclusivo", sub: "Renasça em Cristo e liberte-se dos vícios", badge: "EM BREVE", href: "http://ebook.ricardogonzalesoficial.com.br/", icon: "book", target: "_blank" },
  { label: "Site Oficial", sub: "", badge: "BLOG", href: "http://ricardogonzalesoficial.com.br/", icon: "globe", target: "_blank" },
  { label: "Liturgia Diária", sub: "Palavra do dia", badge: "PALAVRA DO DIA", href: "/liturgia-diaria", icon: "cross", target: "_self" },
  { label: "YouTube", sub: "", href: "https://www.youtube.com/@ricardogonzalesoficial", icon: "youtube", target: "_blank" },
  { label: "Instagram", sub: "", href: "https://instagram.com/ricardogonzalesoficial", icon: "instagram", target: "_blank" },
  { label: "Facebook", sub: "", href: "https://facebook.com/ricardogonzalesoficial", icon: "facebook", target: "_blank" },
  { label: "TikTok", sub: "", href: "https://tiktok.com/@ricardogonzalesoficial", icon: "tiktok", target: "_blank" },
  { label: "Newsletter", sub: "NewsLetter", href: "http://ricardogonzalesoficial.com.br/newsletter", icon: "newsletter", target: "_blank" },
  { label: "Discord", sub: "", href: "https://discord.com/invite/hftJhYQBxE", icon: "discord", target: "_blank" }
];

---

<html lang="pt-BR">
  <head>
    <GoogleTagManagerHead />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Ricardo Gonzales | Fé & Filosofia - Página Oficial de Links"
      description="Página oficial de links de Ricardo Gonzales: fé, filosofia, liturgia diária e redes sociais."
      canonical="https://linksgonzales.vercel.app/"
      openGraph={{
        basic: {
          title: "Ricardo Gonzales | Fé & Filosofia - Página Oficial de Links",
          type: "website",
          image: "og-images/default-og.webp",
          url: "https://linksgonzales.vercel.app/"
        }
      }}
      twitter={{
        card: "summary_large_image",
        site: "@ricardogonzalesoficial",
        creator: "@ricardogonzalesoficial"
      }}
    />
    <style>
      :root {
        --bg: #070707;
        --bg-soft: #111111;
        --card: #0f0f10;
        --line: #2a2a2b;
        --text: #ece7e2;
        --muted: #8f8b88;
        --accent: #ff6a00;
        --accent-soft: #3a1d0a;
      }

      body[data-theme="light"] {
        --bg: #f6f3ef;
        --bg-soft: #ffffff;
        --card: #ffffff;
        --line: #ddd2c8;
        --text: #201a15;
        --muted: #71685f;
        --accent: #d35a00;
        --accent-soft: #ffe9d8;
      }

      * { box-sizing: border-box; }

      *::-webkit-scrollbar {
        width: 10px;
      }

      *::-webkit-scrollbar-track {
        background: #0e0e0f;
      }

      *::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #ff6a00, #bb4300);
        border-radius: 10px;
      }

      body[data-theme="light"] *::-webkit-scrollbar-track {
        background: #efe6dd;
      }

      body[data-theme="light"] *::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #d35a00, #a84a00);
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Georgia", "Times New Roman", serif;
        background: radial-gradient(circle at 50% 10%, #2d0f00 0%, #120b08 30%, var(--bg) 60%);
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 2rem 1rem;
        overflow-x: hidden;
      }

      body[data-theme="light"] {
        background: radial-gradient(circle at 50% 10%, #ffd8be 0%, #f7ece0 40%, var(--bg) 75%);
      }

      #cross-particles {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      .theme-btn {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 2;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: 1px solid #3a3a3a;
        background: #121212cc;
        color: var(--accent);
        cursor: pointer;
        font-size: 1.1rem;
      }

      body[data-theme="light"] .theme-btn {
        background: #ffffffd8;
        border-color: #dbc8b5;
      }

      .shell {
        position: relative;
        z-index: 1;
        width: min(100%, 480px);
        border: 1px solid #252525;
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(18, 18, 18, 0.97), rgba(10, 10, 10, 0.98));
        backdrop-filter: blur(2px);
        padding: 2rem 1.25rem 1.5rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
      }

      body[data-theme="light"] .shell {
        border-color: #dbc8b5;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(252, 246, 240, 0.99));
        box-shadow: 0 20px 60px rgba(73, 35, 0, 0.16);
      }

      .profile {
        display: grid;
        place-items: center;
        gap: 0.8rem;
        margin-bottom: 1.6rem;
      }

      .avatar-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--accent);
        border-radius: 999px;
        padding: 3px;
        box-shadow: 0 0 0 2px rgba(255, 106, 0, 0.4), 0 0 20px rgba(255, 106, 0, 0.5);
        animation: floater 3.6s ease-in-out infinite;
      }

      .avatar {
        width: 76px;
        height: 76px;
        border-radius: 999px;
        object-fit: cover;
        background: linear-gradient(145deg, #3b3b3b, #1d1d1d);
      }

      h1 {
        margin: 0;
        font-size: clamp(1.9rem, 2.7vw, 2.65rem);
        letter-spacing: 0.4px;
        line-height: 1.08;
        text-align: center;
      }

      .tagline {
        margin: 0;
        color: var(--accent);
        font-size: 1.2rem;
        font-style: italic;
      }

      .divider {
        width: 84px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
        margin: 0.35rem 0 0.2rem;
      }

      .links {
        display: grid;
        gap: 0.7rem;
      }

      .link {
        position: relative;
        display: grid;
        grid-template-columns: 42px 1fr auto;
        gap: 0.8rem;
        align-items: center;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 0.9rem 0.95rem;
        background: linear-gradient(90deg, #151515, #171717);
        transition: transform 0.2s ease, border-color 0.2s ease;
      }

      body[data-theme="light"] .link {
        background: linear-gradient(90deg, #ffffff, #f8f2ec);
      }

      .link:hover {
        transform: translateY(-1px);
        border-color: #90481c;
      }

      .link.featured {
        border-color: #a74f15;
        background: linear-gradient(90deg, #2a170b, #1b130f);
      }

      body[data-theme="light"] .link.featured {
        background: linear-gradient(90deg, #fff0e5, #ffe6d2);
      }

      .icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        background: var(--accent-soft);
        border: 1px solid #763812;
        color: var(--accent);
        font-size: 1rem;
        font-weight: 700;
      }

      .icon svg {
        width: 19px;
        height: 19px;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .icon svg.fill {
        fill: currentColor;
        stroke: none;
      }

      .icon svg .fill {
        fill: currentColor;
        stroke: none;
      }

      .txt strong {
        display: block;
        font-size: 1.1rem;
      }

      .txt small {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .badge {
        position: absolute;
        top: -1px;
        right: -1px;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 0.28rem 0.55rem;
        border-top-right-radius: 11px;
        border-bottom-left-radius: 10px;
        background: var(--accent);
        color: #fff;
        letter-spacing: 0.2px;
      }

      .arrow {
        color: #b9b5b1;
        font-size: 1.3rem;
      }

      body[data-theme="light"] .arrow {
        color: #7d7268;
      }

      footer {
        margin-top: 1.6rem;
        text-align: center;
        color: #77726d;
        font-size: 0.88rem;
        line-height: 1.6;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease, color 0.2s ease;
      }

      footer a:hover {
        color: var(--text);
        border-color: currentColor;
      }

      .cookie-banner {
        position: fixed;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 5;
        width: min(94vw, 760px);
        border: 1px solid var(--line);
        background: rgba(15, 15, 16, 0.96);
        backdrop-filter: blur(6px);
        border-radius: 12px;
        padding: 0.85rem;
        display: none;
        gap: 0.8rem;
        align-items: center;
        justify-content: space-between;
      }

      body[data-theme="light"] .cookie-banner {
        background: rgba(255, 255, 255, 0.96);
      }

      .cookie-banner.show {
        display: flex;
      }

      .cookie-text {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .cookie-text a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid currentColor;
      }

      .cookie-actions {
        display: flex;
        gap: 0.5rem;
      }

      .btn {
        border: 1px solid var(--line);
        background: transparent;
        color: var(--text);
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
        cursor: pointer;
      }

      .btn.primary {
        border-color: #9d4a16;
        background: var(--accent);
        color: #fff;
      }

      @keyframes floater {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-6px); }
        100% { transform: translateY(0px); }
      }

      @media (max-width: 520px) {
        .shell { padding: 1.5rem 0.9rem 1.2rem; border-radius: 20px; }
        h1 { font-size: 2rem; }
        .tagline { font-size: 1.05rem; }
        .txt strong { font-size: 1rem; }
        .cookie-banner { flex-direction: column; align-items: stretch; }
        .cookie-actions { justify-content: flex-end; }
      }
    </style>
  </head>

  <body data-theme="dark">
    <GoogleTagManagerBody />
    <svg width="0" height="0" style="position:absolute">
      <symbol id="icon-book" viewBox="0 0 24 24">
        <path d="M4 5.5a2.5 2.5 0 0 1 2.5-2.5H20v16H6.5A2.5 2.5 0 0 0 4 21V5.5Z"/>
        <path d="M4 19a2 2 0 0 1 2-2h14"/>
      </symbol>
      <symbol id="icon-globe" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="9"/>
        <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/>
      </symbol>
      <symbol id="icon-cross" viewBox="0 0 24 24">
        <path d="M12 4v16M8 8h8"/>
      </symbol>
      <symbol id="icon-youtube" viewBox="0 0 24 24">
        <path d="M21.5 8.2c-.2-1.1-1-2-2.2-2.2C17.6 5.7 12 5.7 12 5.7s-5.6 0-7.3.3C3.5 6.2 2.7 7.1 2.5 8.2c-.3 1.8-.3 3.8-.3 3.8s0 2 .3 3.8c.2 1.1 1 2 2.2 2.2 1.7.3 7.3.3 7.3.3s5.6 0 7.3-.3c1.2-.2 2-1.1 2.2-2.2.3-1.8.3-3.8.3-3.8s0-2-.3-3.8Z"/>
        <path d="m10 9 5 3-5 3V9Z" class="fill"/>
      </symbol>
      <symbol id="icon-instagram" viewBox="0 0 24 24">
        <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.2" cy="6.8" r="1.1" class="fill"/>
      </symbol>
      <symbol id="icon-facebook" viewBox="0 0 24 24">
        <path d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v4h4v-4h3l1-4h-4V9c0-.7.3-1 1-1Z"/>
      </symbol>
      <symbol id="icon-tiktok" viewBox="0 0 24 24">
        <path d="M14 5c.7 1.5 2 2.7 3.5 3.2.7.2 1.4.3 2 .3v3.4c-1.7 0-3.3-.4-4.8-1.2v5.1a5.8 5.8 0 1 1-5.8-5.8c.4 0 .8 0 1.1.1v3.4a2.4 2.4 0 1 0 1.3 2.1V5H14Z"/>
      </symbol>
      <symbol id="icon-newsletter" viewBox="0 0 24 24">
        <rect x="3" y="5" width="18" height="14" rx="2"/>
        <path d="m4 7 8 6 8-6"/>
      </symbol>
      <symbol id="icon-discord" viewBox="0 0 24 24">
        <path d="M7 7.5a15 15 0 0 1 10 0 14 14 0 0 1 2 9c-1.6 1.3-3.2 2-5 2.2l-.7-1.5c.7-.1 1.4-.3 2-.7-.2.2-.4.3-.7.4a11 11 0 0 1-5.2 0c-.3-.1-.5-.2-.7-.4.6.4 1.3.6 2 .7L10 18.7c-1.8-.2-3.4-.9-5-2.2a14 14 0 0 1 2-9Z"/>
        <circle cx="9.5" cy="12.5" r="1.1" class="fill"/>
        <circle cx="14.5" cy="12.5" r="1.1" class="fill"/>
      </symbol>
    </svg>

    <canvas id="cross-particles" aria-hidden="true"></canvas>
    <button class="theme-btn" id="theme-btn" aria-label="Alternar tema">☀</button>

    <main class="shell">
      <section class="profile">
        <div class="avatar-wrap">
          <Image src="/ricardo-gonzales.webp" alt="Foto de perfil" width={152} height={152} class="avatar" format="webp" loading="eager" />
        </div>
        <h1>Ricardo Gonzales</h1>
        <p class="tagline">Fé & Filosofia</p>
        <div class="divider"></div>
      </section>

      <section class="links">
        {links.map((item, idx) => (
          <a href={item.href} target={item.target} class={`link ${idx === 0 ? "featured" : ""}`}>
            <span class="icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <use href={`#icon-${item.icon}`}></use>
              </svg>
            </span>
            <span class="txt">
              <strong>{item.label}</strong>
              {item.sub && <small>{item.sub}</small>}
            </span>
            <span class="arrow">→</span>
            {item.badge && <span class="badge">{item.badge}</span>}
          </a>
        ))}
      </section>

      <footer>
        © 2026 Ricardo Gonzales - Fé & Filosofia.<br /> Todos os direitos reservados.<br />
        <a href="http://ricardogonzalesoficial.com.br/termos" aria-label="Termos de Uso">Termos de Uso</a>
        ·
        <a href="http://ricardogonzalesoficial.com.br/privacidade" aria-label="Política de Privacidade">Política de Privacidade</a>
      </footer>
    </main>

    <aside class="cookie-banner" id="cookie-banner" role="dialog" aria-live="polite">
      <div class="cookie-text">
        Este site usa cookies para melhorar sua experiência. Ao continuar, você concorda com nossa
        <a href="http://ricardogonzalesoficial.com.br/privacidade" aria-label="Política de Privacidade">Política de Privacidade</a>.
      </div>
      <div class="cookie-actions">
        <button class="btn" id="cookie-decline">Recusar</button>
        <button class="btn primary" id="cookie-accept">Aceitar</button>
      </div>
    </aside>

    <script>
      const canvas = document.getElementById("cross-particles") as HTMLCanvasElement | null;
      const ctx = canvas?.getContext("2d");
      const crosses: Array<{x: number; y: number; vx: number; vy: number; size: number; alpha: number; pulse: number}> = [];
      const COUNT = 70;

      const themeBtn = document.getElementById("theme-btn") as HTMLElement | null;
      const bodyEl = document.body;
      const savedTheme = localStorage.getItem("theme") || "dark";
      bodyEl.dataset.theme = savedTheme;
      if (themeBtn) themeBtn.textContent = savedTheme === "dark" ? "☀" : "🌙";

      themeBtn?.addEventListener("click", () => {
        const next = bodyEl.dataset.theme === "dark" ? "light" : "dark";
        bodyEl.dataset.theme = next;
        localStorage.setItem("theme", next);
        if (themeBtn) themeBtn.textContent = next === "dark" ? "☀" : "🌙";
      });

      const banner = document.getElementById("cookie-banner") as HTMLElement | null;
      const accepted = localStorage.getItem("cookie-consent");
      if (!accepted && banner) banner.classList.add("show");

      document.getElementById("cookie-accept")?.addEventListener("click", () => {
        localStorage.setItem("cookie-consent", "accepted");
        if (banner) banner.classList.remove("show");
      });

      document.getElementById("cookie-decline")?.addEventListener("click", () => {
        localStorage.setItem("cookie-consent", "declined");
        if (banner) banner.classList.remove("show");
      });

      function resize() {
        const ratio = window.devicePixelRatio || 1;
        if (canvas) {
          canvas.width = Math.floor(window.innerWidth * ratio);
          canvas.height = Math.floor(window.innerHeight * ratio);
          canvas.style.width = window.innerWidth + "px";
          canvas.style.height = window.innerHeight + "px";
        }
        if (ctx) ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      }

      function makeCross() {
        return {
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight,
          vx: (Math.random() - 0.5) * 0.24,
          vy: (Math.random() - 0.5) * 0.24,
          size: Math.random() * 6 + 5,
          alpha: Math.random() * 0.55 + 0.18,
          pulse: Math.random() * Math.PI * 2
        };
      }

      function init() {
        crosses.length = 0;
        for (let i = 0; i < COUNT; i++) crosses.push(makeCross());
      }

      function drawCross(x: number, y: number, size: number, alpha: number) {
        const half = size / 2;
        if (!ctx) return;
        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.strokeStyle = bodyEl.dataset.theme === "dark" ? "#ff6a00" : "#d35a00";
        ctx.lineWidth = 1.05;
        ctx.beginPath();
        ctx.moveTo(x - half, y);
        ctx.lineTo(x + half, y);
        ctx.moveTo(x, y - half);
        ctx.lineTo(x, y + half);
        ctx.stroke();
        ctx.restore();
      }

      function tick() {
        if (!ctx) return;
        ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

        for (const p of crosses) {
          p.x += p.vx;
          p.y += p.vy;
          p.pulse += 0.02;

          if (p.x < -20) p.x = window.innerWidth + 20;
          if (p.x > window.innerWidth + 20) p.x = -20;
          if (p.y < -20) p.y = window.innerHeight + 20;
          if (p.y > window.innerHeight + 20) p.y = -20;

          const pulseAlpha = p.alpha + Math.sin(p.pulse) * 0.12;
          drawCross(p.x, p.y, p.size, Math.max(0.05, pulseAlpha));
        }

        requestAnimationFrame(tick);
      }

      resize();
      init();
      tick();

      window.addEventListener("resize", () => {
        resize();
        init();
      });
    </script>
  </body>
</html>
