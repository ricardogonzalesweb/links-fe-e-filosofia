---
import { SEO } from "astro-seo";
import { Image } from "astro:assets";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";
---

<html lang="pt-BR" data-theme="dark">
  <head>
    <GoogleTagManagerHead />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Liturgia Diária | Ricardo Gonzales Fé & Filosofia"
      description="Acompanhe as leituras da Liturgia Diária: Primeira Leitura, Salmo, Segunda Leitura e Evangelho."
      canonical="https://links.ricardogonzalesoficial.com.br/liturgia-diaria"
      openGraph={{
        basic: {
          title: "Liturgia Diária | Ricardo Gonzales Fé & Filosofia",
          type: "website",
          image: "https://links.ricardogonzalesoficial.com.br/liturgia-diaria/og-images/default-og.webp",
          url: "https://links.ricardogonzalesoficial.com.br/liturgia-diaria"
        }
      }}
      twitter={{
        card: "summary_large_image",
        site: "@ricardogonzalesoficial",
        creator: "@ricardogonzalesoficial"
      }}
    />
    <style>
      :root {
        --bg: #100f0c;
        --bg-soft: #191711;
        --surface: #211f18;
        --surface-2: #2a261d;
        --line: rgba(229, 196, 145, 0.18);
        --text: #f2eadb;
        --muted: #b6a894;
        --subtle: #827565;
        --accent: #f65700;
        --accent-2: #d8a84f;
        --green: #6fb36d;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
      }

      html[data-theme="light"] {
        --bg: #f7f1e8;
        --bg-soft: #fff9f1;
        --surface: #ffffff;
        --surface-2: #f1e7d7;
        --line: rgba(85, 56, 23, 0.16);
        --text: #21180f;
        --muted: #6f6253;
        --subtle: #8c7c68;
        --accent: #d95a00;
        --accent-2: #986819;
        --green: #427f43;
        --shadow: 0 24px 70px rgba(94, 55, 15, 0.18);
      }

      * {
        box-sizing: border-box;
      }

      * {
        scrollbar-width: thin;
        scrollbar-color: var(--accent) var(--bg-soft);
      }

      *::-webkit-scrollbar {
        width: 10px;
      }

      *::-webkit-scrollbar-track {
        background: var(--bg-soft);
      }

      *::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, var(--accent), #9e3b00);
        border: 2px solid var(--bg-soft);
        border-radius: 999px;
      }

      *::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #ff7a2e, var(--accent));
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "DM Sans", "Segoe UI", Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 20% 0%, rgba(246, 87, 0, 0.22), transparent 32rem),
          radial-gradient(circle at 85% 15%, rgba(216, 168, 79, 0.16), transparent 26rem),
          linear-gradient(180deg, var(--bg), #070706);
        overflow-x: hidden;
      }

      html[data-theme="light"] body {
        background:
          radial-gradient(circle at 20% 0%, rgba(246, 87, 0, 0.18), transparent 30rem),
          radial-gradient(circle at 84% 18%, rgba(111, 179, 109, 0.16), transparent 24rem),
          linear-gradient(180deg, var(--bg), #efe3d2);
      }

      #cross-particles {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      a {
        color: inherit;
      }

      .page-shell {
        position: relative;
        z-index: 1;
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        background: color-mix(in srgb, var(--bg) 86%, transparent);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(18px);
      }

      .topbar-inner {
        min-height: 78px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: center;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        min-width: 0;
      }

      .brand-mark {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--accent);
        box-shadow: 0 0 0 3px rgba(246, 87, 0, 0.12);
      }

      .brand-title {
        display: grid;
        gap: 0.08rem;
        min-width: 0;
      }

      .brand-title strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.15rem, 3vw, 1.5rem);
        line-height: 1.05;
        white-space: nowrap;
      }

      .brand-title span {
        color: var(--accent);
        font-size: 0.84rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .top-actions {
        display: flex;
        align-items: center;
        gap: 0.65rem;
      }

      .icon-btn,
      .home-link {
        width: 42px;
        height: 42px;
        border: 1px solid var(--line);
        border-radius: 10px;
        display: inline-grid;
        place-items: center;
        background: var(--surface);
        color: var(--text);
        text-decoration: none;
        transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      }

      .icon-btn:hover,
      .home-link:hover {
        transform: translateY(-1px);
        border-color: var(--accent);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 2rem;
        align-items: end;
        padding: 3rem 0 1.4rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        width: fit-content;
        margin-bottom: 1rem;
        border: 1px solid rgba(246, 87, 0, 0.32);
        border-radius: 999px;
        color: var(--accent);
        background: rgba(246, 87, 0, 0.08);
        padding: 0.35rem 0.8rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.3rem, 7vw, 5.2rem);
        line-height: 0.95;
        max-width: 760px;
      }

      .hero-copy {
        margin: 1rem 0 0;
        max-width: 650px;
        color: var(--muted);
        font-size: clamp(1rem, 2vw, 1.16rem);
        line-height: 1.7;
      }

      .date-panel {
        min-width: 240px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: linear-gradient(180deg, var(--surface), var(--surface-2));
        padding: 1rem;
        box-shadow: var(--shadow);
      }

      .date-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .date-kicker {
        color: var(--subtle);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .stole {
        width: 42px;
        height: 42px;
        object-fit: contain;
        filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.24));
      }

      .current-date {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }

      .current-date strong {
        color: var(--accent);
        font-family: Georgia, "Times New Roman", serif;
        font-size: 3.35rem;
        line-height: 0.9;
      }

      .current-date span {
        display: block;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .calendar-wrap {
        position: relative;
        margin-top: 1rem;
      }

      .calendar-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        border: 1px solid rgba(246, 87, 0, 0.34);
        border-radius: 8px;
        background: rgba(246, 87, 0, 0.09);
        color: var(--accent);
        padding: 0.7rem 0.9rem;
        font-weight: 800;
      }

      .calendar-dropdown {
        position: absolute;
        right: 0;
        top: calc(100% + 0.7rem);
        z-index: 30;
        width: 310px;
        max-width: calc(100vw - 2rem);
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow);
        padding: 0.9rem;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-6px);
        transition: opacity 0.18s ease, transform 0.18s ease;
      }

      .calendar-dropdown.active {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .calendar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px solid var(--line);
      }

      .calendar-title {
        display: grid;
        text-align: center;
        font-weight: 800;
        text-transform: capitalize;
      }

      .calendar-title small {
        color: var(--subtle);
        font-size: 0.8rem;
      }

      .calendar-nav {
        width: 32px;
        height: 32px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface-2);
        color: var(--accent);
      }

      .calendar-weekdays,
      .calendar-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 0.25rem;
      }

      .calendar-weekdays {
        margin: 0.75rem 0 0.35rem;
      }

      .weekday {
        color: var(--subtle);
        font-size: 0.66rem;
        font-weight: 800;
        text-align: center;
        text-transform: uppercase;
      }

      .calendar-day {
        aspect-ratio: 1;
        border: 1px solid transparent;
        border-radius: 8px;
        background: transparent;
        color: var(--text);
        font-size: 0.84rem;
      }

      .calendar-day:not(:disabled):hover,
      .calendar-day.selected,
      .calendar-day.today {
        border-color: var(--accent);
        background: var(--accent);
        color: #fff;
      }

      .calendar-day.selected {
        box-shadow: 0 0 0 3px rgba(246, 87, 0, 0.16);
      }

      .calendar-day.other-month {
        color: var(--subtle);
        opacity: 0.45;
      }

      .content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 1.2rem;
        align-items: start;
        padding-bottom: 3rem;
      }

      .liturgy-card,
      .side-card {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: color-mix(in srgb, var(--surface) 94%, transparent);
        box-shadow: var(--shadow);
      }

      .liturgy-card {
        min-width: 0;
      }

      .liturgy-head {
        padding: clamp(1rem, 3vw, 1.55rem);
        border-bottom: 1px solid var(--line);
      }

      .liturgical-color {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        width: fit-content;
        margin-bottom: 0.85rem;
        color: var(--accent-2);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .liturgical-color::before {
        content: "";
        width: 0.58rem;
        height: 0.58rem;
        border-radius: 50%;
        background: var(--liturgical-dot, var(--accent));
      }

      .day-title {
        margin: 0;
        color: var(--text);
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.45rem, 4vw, 2.25rem);
        line-height: 1.18;
        white-space: pre-wrap;
      }

      .tabs {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        padding: 1rem clamp(1rem, 3vw, 1.55rem) 0;
      }

      .tab-btn {
        border: 1px solid rgba(246, 87, 0, 0.34);
        border-radius: 999px;
        background: rgba(246, 87, 0, 0.08);
        color: var(--accent);
        padding: 0.58rem 0.95rem;
        font-weight: 800;
        font-size: 0.9rem;
      }

      .tab-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
      }

      .reading {
        padding: clamp(1rem, 3vw, 1.55rem);
      }

      .reading-box {
        min-height: 390px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--bg-soft);
        padding: clamp(1rem, 3vw, 1.55rem);
      }

      .reading-box h2,
      .reading-box h3 {
        margin: 0 0 0.65rem;
        font-family: Georgia, "Times New Roman", serif;
        line-height: 1.2;
      }

      .reading-box p {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 1.03rem;
        line-height: 1.9;
        white-space: pre-line;
      }

      .verse-number {
        color: var(--accent);
        font-size: 0.72em;
        font-weight: 900;
        vertical-align: super;
        margin-right: 0.16rem;
      }

      .status {
        color: var(--muted);
        font-weight: 700;
      }

      .status.error {
        color: #ff9a74;
      }

      .reading-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1rem;
        color: var(--subtle);
        font-size: 0.85rem;
      }

      .share-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border: 1px solid var(--accent);
        border-radius: 999px;
        background: transparent;
        color: var(--accent);
        padding: 0.6rem 0.95rem;
        font-weight: 800;
      }

      .share-btn:hover {
        background: var(--accent);
        color: #fff;
      }

      .side-card {
        padding: 1rem;
      }

      .side-card + .side-card {
        margin-top: 1rem;
      }

      .side-card h2 {
        margin: 0 0 0.65rem;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 1.22rem;
      }

      .side-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
      }

      .saint-date {
        display: inline-flex;
        margin-bottom: 0.55rem;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .saint-summary {
        margin-top: 0.7rem;
      }

      .verse {
        color: var(--accent-2);
        font-style: italic;
      }

      .footer {
        position: relative;
        z-index: 1;
        background: color-mix(in srgb, var(--bg) 88%, #000 12%);
        border-top: 1px solid var(--line);
        padding: 3.4rem 0 1.8rem;
        color: var(--subtle);
        font-size: 0.86rem;
      }

      .footer-inner {
        display: grid;
        grid-template-columns: 1.6fr 0.7fr 1fr;
        gap: clamp(1.5rem, 6vw, 5rem);
        align-items: start;
      }

      .footer-brand h2,
      .footer-column h2 {
        margin: 0 0 1rem;
        font-family: Georgia, "Times New Roman", serif;
        line-height: 1.1;
      }

      .footer-brand h2 {
        color: var(--text);
        font-size: 1.2rem;
        letter-spacing: 0.02em;
      }

      .footer-column h2 {
        color: var(--accent-2);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .footer-brand p,
      .footer-bottom {
        color: var(--subtle);
      }

      .footer-brand p {
        max-width: 390px;
        margin: 0;
        line-height: 1.7;
      }

      .footer-verse {
        margin-top: 3rem;
        max-width: 420px;
      }

      .footer-verse p {
        margin: 0 0 0.7rem;
        color: var(--muted);
        font-style: italic;
        line-height: 1.7;
      }

      .footer-verse strong {
        color: var(--accent);
      }

      .footer-links {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }

      .footer-links a {
        width: fit-content;
        color: var(--text);
        text-decoration: none;
        transition: color 0.2s ease, transform 0.2s ease;
      }

      .footer-links a:hover {
        color: var(--accent);
        transform: translateX(3px);
      }

      .social-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .social-link {
        width: 2.45rem;
        height: 2.45rem;
        display: inline-grid;
        place-items: center;
        border: 1px solid rgba(246, 87, 0, 0.34);
        border-radius: 12px;
        color: var(--text);
        background: rgba(246, 87, 0, 0.04);
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }

      .social-link:hover {
        background: var(--accent);
        color: #fff;
        transform: translateY(-2px);
      }

      .social-link svg {
        width: 1.08rem;
        height: 1.08rem;
        fill: currentColor;
      }

      .footer-divider {
        width: 100%;
        height: 1px;
        margin: 2.6rem 0 1.6rem;
        background: var(--line);
      }

      .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .footer-love {
        display: inline-flex;
        align-items: center;
        gap: 0.32rem;
      }

      .footer-love svg {
        width: 0.95rem;
        height: 0.95rem;
        fill: var(--accent);
      }

      .cookie-banner {
        position: fixed;
        z-index: 40;
        left: 50%;
        bottom: 1rem;
        width: min(720px, calc(100% - 2rem));
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow);
        padding: 1rem;
        transform: translate(-50%, 130%);
        transition: transform 0.28s ease;
      }

      .cookie-banner.show {
        transform: translate(-50%, 0);
      }

      .cookie-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .cookie-content p {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.55;
      }

      .cookie-actions {
        display: flex;
        gap: 0.5rem;
        flex-shrink: 0;
      }

      .cookie-actions button {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 0.55rem 0.8rem;
        background: transparent;
        color: var(--text);
        font-weight: 800;
      }

      .cookie-actions .accept {
        border-color: var(--accent);
        background: var(--accent);
        color: #fff;
      }

      @media (max-width: 860px) {
        .hero,
        .content-grid {
          grid-template-columns: 1fr;
        }

        .date-panel {
          width: 100%;
        }

        .calendar-dropdown {
          left: 0;
          right: auto;
          width: min(330px, 100%);
        }

        .side {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 1rem;
        }

        .saint-card {
          grid-column: 1 / -1;
        }

        .side-card + .side-card {
          margin-top: 0;
        }
      }

      @media (max-width: 620px) {
        .page-shell {
          width: min(100% - 1rem, 1120px);
        }

        .topbar-inner {
          grid-template-columns: 1fr;
          gap: 0.8rem;
          padding: 0.85rem 0;
        }

        .top-actions {
          justify-content: space-between;
        }

        .hero {
          padding-top: 2rem;
        }

        .side,
        .cookie-content {
          grid-template-columns: 1fr;
          display: grid;
        }

        .footer-inner {
          grid-template-columns: 1fr;
        }

        .footer-verse {
          margin-top: 2rem;
        }

        .footer-bottom {
          align-items: flex-start;
          flex-direction: column;
        }

        .cookie-actions {
          justify-content: end;
        }
      }
    </style>
  </head>
  <body>
    <GoogleTagManagerBody />
    <canvas id="cross-particles" aria-hidden="true"></canvas>

    <header class="topbar">
      <div class="page-shell topbar-inner">
        <a class="brand" href="/" aria-label="Voltar para a página de links">
          <Image src="/ricardo-gonzales.png" alt="Ricardo Gonzales" width={92} height={92} class="brand-mark" format="webp" loading="eager" />
          <span class="brand-title">
            <strong>Liturgia Diária</strong>
            <span>Fé & Filosofia</span>
          </span>
        </a>

        <div class="top-actions">
          <a class="home-link" href="/" title="Voltar" aria-label="Voltar para a página inicial">
            <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <button class="icon-btn" id="themeToggle" type="button" title="Alternar tema" aria-label="Alternar tema">
            <svg id="themeSun" width="19" height="19" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main class="page-shell">
      <section class="hero" aria-labelledby="page-title">
        <div>
          <span class="eyebrow">Palavra do dia</span>
          <h1 id="page-title">Liturgia Diária</h1>
          <p class="hero-copy">
