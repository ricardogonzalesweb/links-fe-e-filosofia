    <script>
      const liturgyState = {
        data: null,
        activeReading: "primeiraLeitura",
        currentCalendarDate: new Date(),
        selectedDate: new Date()
      };

      const elements = {
        html: document.documentElement,
        themeToggle: document.getElementById("themeToggle"),
        dayNumber: document.getElementById("dayNumber"),
        monthName: document.getElementById("monthName"),
        yearNumber: document.getElementById("yearNumber"),
        dateInput: document.getElementById("dateInput") as HTMLInputElement,
        calendarTrigger: document.getElementById("calendarTrigger"),
        calendarDropdown: document.getElementById("calendarDropdown"),
        calendarMonth: document.getElementById("calendarMonth"),
        calendarYear: document.getElementById("calendarYear"),
        calendarDays: document.getElementById("calendarDays"),
        prevMonth: document.getElementById("prevMonth"),
        nextMonth: document.getElementById("nextMonth"),
        liturgicalColor: document.getElementById("liturgicalColor"),
        colorDescription: document.getElementById("colorDescription"),
        dayTitle: document.getElementById("dayTitle"),
        stoleImage: document.getElementById("stoleImage") as HTMLImageElement,
        readingText: document.getElementById("readingText"),
        shareLiturgy: document.getElementById("shareLiturgy"),
        saintDate: document.getElementById("saintDate"),
        saintTitle: document.getElementById("saintTitle"),
        saintSummary: document.getElementById("saintSummary"),
        cookieBanner: document.getElementById("cookieBanner"),
        acceptCookies: document.getElementById("acceptCookies"),
        declineCookies: document.getElementById("declineCookies"),
        currentYear: document.getElementById("currentYear")
      };

      const liturgicalColors = {
        Verde: { file: "verde.png", dot: "#3d8c49", description: "Verde: esperança, crescimento espiritual e tempo comum." },
        Roxo: { file: "roxo.png", dot: "#7c4bc1", description: "Roxo: penitência, preparação, Advento e Quaresma." },
        Branco: { file: "branco.png", dot: "#f6efe1", description: "Branco: alegria, solenidade, festas do Senhor e dos santos." },
        Vermelho: { file: "vermelho.png", dot: "#c73b2b", description: "Vermelho: martírio, paixão, fogo do Espírito Santo e Pentecostes." },
        Rosa: { file: "rosa.png", dot: "#d77b9c", description: "Rosa: alegria serena no Advento e na Quaresma." }
      };

      function pad(value) {
        return String(value).padStart(2, "0");
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function formatVerseNumbers(value) {
        return escapeHtml(value).replace(/(\d+)/g, '<span class="verse-number">$1</span>');
      }

      function getDateParts(date) {
        return {
          day: pad(date.getDate()),
          month: pad(date.getMonth() + 1),
          year: date.getFullYear()
        };
      }

      function setDisplayedDate(date) {
        const parts = getDateParts(date);
        elements.dayNumber.textContent = parts.day;
        elements.monthName.textContent = date.toLocaleDateString("pt-BR", { month: "short" }).replace(".", "").toUpperCase();
        elements.yearNumber.textContent = String(parts.year);
        elements.dateInput.value = `${parts.year}-${parts.month}-${parts.day}`;
      }

      function applyTheme(theme) {
        elements.html.setAttribute("data-theme", theme);
        localStorage.setItem("ldTheme", theme);
      }

      function initTheme() {
        applyTheme(localStorage.getItem("ldTheme") || "dark");
        elements.themeToggle.addEventListener("click", () => {
          applyTheme(elements.html.getAttribute("data-theme") === "dark" ? "light" : "dark");
        });
      }

      function openCalendar() {
        elements.calendarDropdown.classList.add("active");
        elements.calendarTrigger.setAttribute("aria-expanded", "true");
        renderCalendar(liturgyState.currentCalendarDate);
      }

      function closeCalendar() {
        elements.calendarDropdown.classList.remove("active");
        elements.calendarTrigger.setAttribute("aria-expanded", "false");
      }

      function renderCalendar(date) {
        const year = date.getFullYear();
        const month = date.getMonth();
        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const prevLastDay = new Date(year, month, 0);
        const adjustedStart = firstDay.getDay() === 0 ? 6 : firstDay.getDay() - 1;

        elements.calendarMonth.textContent = date.toLocaleDateString("pt-BR", { month: "long" });
        elements.calendarYear.textContent = String(year);
        elements.calendarDays.innerHTML = "";

        for (let i = adjustedStart - 1; i >= 0; i -= 1) {
          const button = document.createElement("button");
          button.className = "calendar-day other-month";
          button.type = "button";
          button.disabled = true;
          button.textContent = String(prevLastDay.getDate() - i);
          elements.calendarDays.appendChild(button);
        }

        const today = new Date();
        for (let day = 1; day <= lastDay.getDate(); day += 1) {
          const button = document.createElement("button");
          const candidate = new Date(year, month, day);
          button.className = "calendar-day";
          button.type = "button";
          button.textContent = String(day);

          if (candidate.toDateString() === today.toDateString()) button.classList.add("today");
          if (candidate.toDateString() === liturgyState.selectedDate.toDateString()) button.classList.add("selected");

          button.addEventListener("click", () => selectDate(candidate));
          elements.calendarDays.appendChild(button);
        }

        const totalCells = elements.calendarDays.children.length;
        for (let day = 1; day <= 42 - totalCells; day += 1) {
          const button = document.createElement("button");
          button.className = "calendar-day other-month";
          button.type = "button";
          button.disabled = true;
          button.textContent = String(day);
          elements.calendarDays.appendChild(button);
        }
      }

      function initCalendar() {
        elements.calendarTrigger.addEventListener("click", () => {
          elements.calendarDropdown.classList.contains("active") ? closeCalendar() : openCalendar();
        });

        elements.prevMonth.addEventListener("click", () => {
          liturgyState.currentCalendarDate.setMonth(liturgyState.currentCalendarDate.getMonth() - 1);
          renderCalendar(liturgyState.currentCalendarDate);
        });

        elements.nextMonth.addEventListener("click", () => {
          liturgyState.currentCalendarDate.setMonth(liturgyState.currentCalendarDate.getMonth() + 1);
          renderCalendar(liturgyState.currentCalendarDate);
        });

        document.addEventListener("click", (event) => {
          if (!(event.target as Element).closest(".calendar-wrap")) closeCalendar();
        });
      }

      async function selectDate(date) {
        liturgyState.selectedDate = new Date(date);
        liturgyState.currentCalendarDate = new Date(date.getFullYear(), date.getMonth(), 1);
        setDisplayedDate(date);
        closeCalendar();
        await fetchLiturgy(date);
      }

      function setLoading() {
        elements.liturgicalColor.textContent = "Carregando";
        elements.dayTitle.textContent = "Buscando liturgia...";
        elements.readingText.innerHTML = '<p class="status">Carregando a liturgia selecionada...</p>';
      }

      function updateLiturgicalColor(color) {
        const config = liturgicalColors[color] || liturgicalColors.Branco;
        elements.stoleImage.src = `https://liturgiadiaria.edicoescnbb.com.br/estolas/${config.file}`;
        elements.liturgicalColor.textContent = `Cor litúrgica: ${color || "Branco"}`;
        elements.liturgicalColor.style.setProperty("--liturgical-dot", config.dot);
        elements.colorDescription.textContent = config.description;
      }

      async function fetchLiturgy(date) {
        const { day, month, year } = getDateParts(date);
        setLoading();

        try {
          const response = await fetch(`https://liturgia.up.railway.app/?dia=${day}&mes=${month}&ano=${year}`);
          if (!response.ok) throw new Error(`Erro na API: ${response.status}`);

          const data = await response.json();
          if (!data || Object.keys(data).length === 0) throw new Error("Nenhum dado encontrado.");

          liturgyState.data = data;
          elements.dayTitle.textContent = data.liturgia || "Liturgia do dia";
          updateLiturgicalColor(data.cor);
          updateCelebration(data, date);
          renderReading(liturgyState.activeReading);
        } catch (error) {
          liturgyState.data = null;
          elements.liturgicalColor.textContent = "Indisponível";
          elements.dayTitle.textContent = "Não foi possível carregar esta data";
          elements.readingText.innerHTML = '<p class="status error">Nenhuma liturgia encontrada para essa data ou a API está indisponível no momento.</p>';
          updateCelebration(null, date);
          console.error(error);
        }
      }

      function summarizePrayer(text) {
        const cleanText = String(text || "").replace(/\s+/g, " ").trim();
        if (!cleanText) return "A celebração será atualizada junto com a liturgia selecionada.";
        return cleanText.length > 300 ? `${cleanText.slice(0, 297).trim()}...` : cleanText;
      }

      function updateCelebration(data, date) {
        const { day, month, year } = getDateParts(date);
        elements.saintDate.textContent = `${day}/${month}/${year}`;
        if (!data) {
          elements.saintTitle.textContent = "Celebração do Dia";
          elements.saintSummary.textContent = "Não foi possível carregar a celebração desta data no momento.";
          return;
        }

        elements.saintTitle.textContent = data.liturgia || "Celebração do Dia";
        elements.saintSummary.textContent = summarizePrayer(data.dia);
      }

      function readingTemplate(type, data) {
        if (type === "primeiraLeitura" && data.primeiraLeitura) {
          return `
            <h2>Primeira Leitura (${escapeHtml(data.primeiraLeitura.referencia)})</h2>
            <h3>${escapeHtml(data.primeiraLeitura.titulo)}</h3>
            <p>${formatVerseNumbers(data.primeiraLeitura.texto)}</p>
            <p><strong>Palavra do Senhor.</strong><br />Graças a Deus.</p>
          `;
        }

        if (type === "segundaLeitura") {
          if (!data.segundaLeitura || data.segundaLeitura === "Não há segunda leitura hoje!") {
            return '<p class="status">Não há segunda leitura hoje.</p>';
          }
          return `
            <h2>Segunda Leitura (${escapeHtml(data.segundaLeitura.referencia)})</h2>
            <h3>${escapeHtml(data.segundaLeitura.titulo)}</h3>
            <p>${formatVerseNumbers(data.segundaLeitura.texto)}</p>
            <p><strong>Palavra do Senhor.</strong><br />Graças a Deus.</p>
          `;
        }

        if (type === "salmo" && data.salmo) {
          return `
            <h2>Salmo Responsorial (${escapeHtml(data.salmo.referencia)})</h2>
            <p><strong>${escapeHtml(data.salmo.refrao)}</strong></p>
            <p>${formatVerseNumbers(data.salmo.texto)}</p>
          `;
        }

        if (type === "evangelho" && data.evangelho) {
          return `
            <h2>Evangelho (${escapeHtml(data.evangelho.referencia)})</h2>
            <h3>${escapeHtml(data.evangelho.titulo)}</h3>
            <p><strong>Glória a vós, Senhor!</strong></p>
            <p>${formatVerseNumbers(data.evangelho.texto)}</p>
            <p><strong>Palavra da Salvação.</strong><br />Glória a vós, Senhor!</p>
          `;
        }

        return '<p class="status">Nenhuma leitura disponível para o dia escolhido.</p>';
      }

      function renderReading(type) {
        if (!liturgyState.data) return;
        liturgyState.activeReading = type;
        document.querySelectorAll(".tab-btn").forEach((button) => {
          button.classList.toggle("active", (button as HTMLButtonElement).dataset.reading === type);
        });
        elements.readingText.innerHTML = readingTemplate(type, liturgyState.data);
      }

      function initTabs() {
        document.querySelectorAll(".tab-btn").forEach((button) => {
          button.addEventListener("click", () => renderReading((button as HTMLButtonElement).dataset.reading));
        });
      }

      function initShare() {
        elements.shareLiturgy.addEventListener("click", async () => {
          const shareData = {
            title: "Liturgia Diária",
            text: elements.dayTitle.textContent || "Confira a liturgia de hoje.",
            url: window.location.href
          };

          if (navigator.share) {
            await navigator.share(shareData).catch(() => {});
            return;
          }

          if (navigator.clipboard) {
            await navigator.clipboard.writeText(shareData.url);
            elements.shareLiturgy.textContent = "Link copiado";
            setTimeout(() => {
              elements.shareLiturgy.innerHTML = `
                <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="18" cy="5" r="3" fill="none" stroke="currentColor" stroke-width="2" />
                  <circle cx="6" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2" />
                  <circle cx="18" cy="19" r="3" fill="none" stroke="currentColor" stroke-width="2" />
                  <path d="M8.6 10.7l6.8-4.4M8.6 13.3l6.8 4.4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                Compartilhar
              `;
            }, 1800);
          }
        });
      }

      function initCookies() {
        if (!localStorage.getItem("ldCookies")) {
          setTimeout(() => elements.cookieBanner.classList.add("show"), 1000);
        }

        elements.acceptCookies.addEventListener("click", () => {
          localStorage.setItem("ldCookies", "accepted");
          elements.cookieBanner.classList.remove("show");
        });

        elements.declineCookies.addEventListener("click", () => {
          localStorage.setItem("ldCookies", "declined");
          elements.cookieBanner.classList.remove("show");
        });
      }

      function initParticles() {
        const canvas = document.getElementById("cross-particles") as HTMLCanvasElement | null;
        const ctx = canvas?.getContext("2d");
        const crosses = [];
        const count = 70;

        if (!canvas || !ctx) return;

        function resizeParticles() {
          const ratio = window.devicePixelRatio || 1;
          canvas.width = Math.floor(window.innerWidth * ratio);
          canvas.height = Math.floor(window.innerHeight * ratio);
          canvas.style.width = `${window.innerWidth}px`;
          canvas.style.height = `${window.innerHeight}px`;
          ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
        }

        function makeCross() {
          return {
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            vx: (Math.random() - 0.5) * 0.24,
            vy: (Math.random() - 0.5) * 0.24,
            size: Math.random() * 6 + 5,
            alpha: Math.random() * 0.55 + 0.18,
            pulse: Math.random() * Math.PI * 2
          };
        }

        function seedParticles() {
          crosses.length = 0;
          for (let i = 0; i < count; i += 1) crosses.push(makeCross());
        }

        function drawCross(x, y, size, alpha) {
          const half = size / 2;
          ctx.save();
          ctx.globalAlpha = alpha;
          ctx.strokeStyle = elements.html.getAttribute("data-theme") === "dark" ? "#ff6a00" : "#d35a00";
          ctx.lineWidth = 1.05;
          ctx.beginPath();
          ctx.moveTo(x - half, y);
          ctx.lineTo(x + half, y);
          ctx.moveTo(x, y - half);
          ctx.lineTo(x, y + half);
          ctx.stroke();
          ctx.restore();
        }

        function tickParticles() {
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

          for (const particle of crosses) {
            particle.x += particle.vx;
            particle.y += particle.vy;
            particle.pulse += 0.02;

            if (particle.x < -20) particle.x = window.innerWidth + 20;
            if (particle.x > window.innerWidth + 20) particle.x = -20;
            if (particle.y < -20) particle.y = window.innerHeight + 20;
            if (particle.y > window.innerHeight + 20) particle.y = -20;

            const pulseAlpha = particle.alpha + Math.sin(particle.pulse) * 0.12;
            drawCross(particle.x, particle.y, particle.size, Math.max(0.05, pulseAlpha));
          }

          requestAnimationFrame(tickParticles);
        }

        resizeParticles();
        seedParticles();
        tickParticles();

        window.addEventListener("resize", () => {
          resizeParticles();
          seedParticles();
        });
      }

      function init() {
        const today = new Date();
        liturgyState.currentCalendarDate = new Date(today.getFullYear(), today.getMonth(), 1);
        liturgyState.selectedDate = today;
        elements.currentYear.textContent = String(today.getFullYear());

        initTheme();
        initCalendar();
        initTabs();
        initShare();
        initCookies();
        initParticles();
        setDisplayedDate(today);
        fetchLiturgy(today);
      }

      init();
    </script>
  </body>
</html>
